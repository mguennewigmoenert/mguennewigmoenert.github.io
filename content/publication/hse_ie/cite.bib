author = {Günnewig-Mönert, Maximilian and Lyons, Ronan C.},
title = {Housing prices, costs, and policy: The housing supply equation in Ireland since 1970},
journal = {Real Estate Economics},
volume = {52},
number = {4},
pages = {1075-1102},
keywords = {housing supply elasticity, Ireland, error correction},
doi = {https://doi.org/10.1111/1540-6229.12491},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/1540-6229.12491},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/1540-6229.12491},
abstract = {Abstract This article examines the responsiveness of new housing supply to prices and costs, using the case of Ireland at quarterly frequency from the 1970s, as well as a county-level panel from the 1990s. Across four error-correction specifications, and supported by an instrumental variables approach, we find the estimated elasticity of new housing supply to prices of +0.9 in the baseline, while that of costs is larger in magnitude (−1.9). We present evidence that responsiveness to prices rose after the 1980s, then fell in the 2000s, before rising again and also that elasticities vary at the county level.},
year = {2024}
}
